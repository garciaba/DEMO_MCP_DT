# GitHub OAuth App credentials
# Create one at: https://github.com/settings/applications/new
# Set callback URL to: http://localhost:5173
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cookie signing secret (auto-generated if not set)
COOKIE_SECRET=

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Production CORS — set to your deployed frontend URL (e.g. https://myapp.example.com)
# Leave empty in development (auto-allows localhost:5173)
ALLOWED_ORIGIN=

# ─── OpenTelemetry / OpenLLMetry ─────────────────────────────
# Dynatrace OTLP ingest endpoint (replace <env-id> with your environment)
# For Dynatrace SaaS: https://<env-id>.live.dynatrace.com/api/v2/otlp
# For Dynatrace Managed: https://<domain>/e/<env-id>/api/v2/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=

# Dynatrace API token with 'openTelemetryTrace.ingest' and 'metrics.ingest' scopes
# Format: Api-Token <token>
OTEL_EXPORTER_OTLP_HEADERS=

OTEL_SERVICE_NAME=dynatrace-observability-assistant
OTEL_SERVICE_VERSION=1.0.0
